# 셋 중 하나 이상 설정하세요. 우선순위는 LLM_PROVIDER로 지정 (미지정 시 anthropic → openai → gemini 순 시도)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# 선택: 사용할 제공자 강제 지정 (anthropic | openai | gemini)
LLM_PROVIDER=openai

# 선택: 모델 오버라이드
# ANTHROPIC_MODEL=claude-opus-4-7
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash

BLOG_ID=1234567890123456789

# 주제 자동 생성 옵션
BLOG_THEME=일상 팁, 자기계발, IT/기술, 취미, 생산성
AUTO_TOPIC=0

# 이미지/비디오 (Pixabay 무료, https://pixabay.com/api/docs/ 에서 발급)
PIXABAY_API_KEY=
EMBED_VIDEO=1
